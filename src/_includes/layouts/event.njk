---
layout: base.njk
fullWidth: true
bodyClass: page-event
---

<!-- ── EVENT HERO ────────────────────────── -->
<section class="cosmos-page-hero cosmos-page-hero--events">
  <div class="container">
    <a href="/events/" class="cosmos-back-link cosmos-back-link--events"><i class="bi bi-arrow-left me-1"></i>All Events</a>
    <h1 class="cosmos-section__title cosmos-section__title--events mb-3 mt-2">{{ title }}</h1>
    {% if not hideEventDetails %}
    <div class="cosmos-event-detail-meta">
      {% include "partials/event-details.njk" %}
    </div>
    {% endif %}
  </div>
</section>

<!-- ── CONTENT ────────────────────────────── -->
<section class="cosmos-section">
  <div class="container">

    {%- set linkedPost = null %}
    {%- if recapPost %}
      {%- for p in collections.posts %}
        {%- if p.url == recapPost %}{% set linkedPost = p %}{% endif %}
      {%- endfor %}
    {%- endif %}

    {%- if linkedPost %}
    <a href="{{ linkedPost.url }}" class="cosmos-recap-preview mb-4">
      {% if linkedPost.data.image %}<img src="{{ linkedPost.data.image }}" alt="" class="cosmos-recap-preview__image">{% endif %}
      <div class="cosmos-recap-preview__body">
        <span class="cosmos-badge cosmos-badge--primary mb-2"><i class="bi bi-stickies"></i>Recap</span>
        <h5 class="cosmos-recap-preview__title">{{ linkedPost.data.title }}</h5>
        {% if linkedPost.data.description %}<p class="cosmos-recap-preview__desc">{{ linkedPost.data.description }}</p>{% endif %}
        <span class="cosmos-recap-preview__link">Read the recap <i class="bi bi-arrow-right"></i></span>
      </div>
    </a>
    {%- elif recapPost %}
    <p class="mb-4">Read the <a href="{{ recapPost }}" style="color:var(--color-events);">recap post</a>.</p>
    {%- endif %}

    {{ content | safe }}

    {%- if gallery and not (content | hasGallery) %}
    {% set path = gallery | stripLeadingSlash %}
    {% include "partials/gallery.njk" %}
    {%- endif %}

    {%- set showMergedGallery = mergeGallery or (linkedPost and linkedPost.data.mergeGallery) %}
    {%- if showMergedGallery and linkedPost and linkedPost.data.gallery and linkedPost.data.gallery != gallery %}
    {% set path = linkedPost.data.gallery | stripLeadingSlash %}
    {% include "partials/gallery.njk" %}
    {%- endif %}

    <div class="d-flex gap-3 mt-5 flex-wrap">
      <a href="/events/" class="btn btn-outline-primary"><i class="bi bi-arrow-left me-2"></i>All Events</a>
      <a href="https://lu.ma/localai" class="btn cosmos-glow-btn cosmos-glow-btn--events" target="_blank" rel="noopener">
        <i class="bi bi-calendar-plus me-2"></i>Follow for events<i class="bi bi-box-arrow-up-right ms-2 small"></i>
      </a>
    </div>

  </div>
</section>
